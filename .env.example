# ============================================================
# Stockfela – Environment Variables Template
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# Usage (local dev):
#   cp .env.example .env
#   # edit .env with your values
#   # Spring Boot picks these up automatically when using
#   # spring-dotenv or when passed as JVM args / OS env vars
#
# Usage (production / CI):
#   Set each variable in your cloud platform / CI secrets manager.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# Switch from H2 to MySQL by uncommenting and filling these in.
# DB_URL=jdbc:mysql://localhost:3306/stockfela_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DB_USERNAME=stockfela_user
# DB_PASSWORD=change_me_strong_password

# ─── JWT ─────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=replace_with_at_least_64_character_base64_encoded_secret_key_here_xxxxxxxxxxx
# Token lifetime in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000

# ─── Google OAuth2 (optional – leave blank to disable) ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Server ──────────────────────────────────────────────────
SERVER_PORT=8080

# ─── CORS allowed origins ────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5174

# ─── Application limits ──────────────────────────────────────
APP_MAX_GROUP_MEMBERS=20
APP_DEFAULT_CYCLE_MONTHS=12
